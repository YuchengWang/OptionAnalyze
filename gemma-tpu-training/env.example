# --- ☁️ Google Cloud Configuration ---
PROJECT_ID="your-project-id"
ZONE="us-south1-a"
NODE_ID="tpu-gemma3-unique-name"
ACCELERATOR_TYPE="v5litepod-1"
VERSION="v2-tpuv5-lite-cgroup1"
REMOTE_DIR="~/gemma-tpu-training"

# --- 🧠 Model & Auth Configuration ---
MODEL_ID="google/gemma-3-1b-it"
HF_TOKEN="your-huggingface-token-here"

# --- ⚙️ JAX/XLA TPU Runtime Settings ---
XLA_USE_BF16=1
JAX_PLATFORMS="tpu,cpu"
XLA_PYTHON_CLIENT_PREALLOCATE="false"
XLA_PYTHON_CLIENT_MEM_FRACTION=".80"
XLA_PYTHON_CLIENT_ALLOCATOR="platform"

# --- 📝 Training Hyperparameters ---
LEARNING_RATE=1e-5
LORA_RANK=8
MAX_SEQ_LEN=768
NUM_EPOCHS=1
